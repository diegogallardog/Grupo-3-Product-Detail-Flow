              "    pm.expect(body).to.have.property(\"cat\");",
              "    pm.expect(body).to.have.property(\"desc\");",
              "    pm.expect(body).to.have.property(\"id\");",
              "    pm.expect(body).to.have.property(\"img\");",
              "    pm.expect(body).to.have.property(\"price\");",
              "    pm.expect(body).to.have.property(\"title\");",
              "});",
              "// Validar que los campos no están vacíos",
              "pm.test(\"Campos title, desc y price tienen valores válidos\", function () {",
